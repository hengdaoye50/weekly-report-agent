# 飞书应用凭证
FEISHU_APP_ID=your_app_id
FEISHU_APP_SECRET=your_app_secret

# 飞书文档配置
FEISHU_SOURCE_DOC_ID=your_source_doc_id
FEISHU_OUTPUT_FOLDER_TOKEN=your_folder_token
